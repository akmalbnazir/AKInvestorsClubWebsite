# Environment variables for AKIC Ultra v5 (Vercel)
# Copy to `.env.local` for local dev. On Vercel, set these in Project Settings → Environment Variables
# Supabase Postgres connection string (provided automatically by Vercel ↔ Supabase integration as DATABASE_URL)
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Restrict signups/logins to this email domain
ALLOWED_DOMAIN=@student.cms.k12.nc.us

# Optional: AlphaVantage API key for stock data (falls back to 'demo')
ALPHA_VANTAGE_KEY=demo

# Seed/admin bootstrap accounts (only used by prisma/seed.js)
ADMIN1_EMAIL=president@example.edu
ADMIN1_PASSWORD=change-me-strong
ADMIN2_EMAIL=exec.tech@example.edu
ADMIN2_PASSWORD=change-me-strong
ADMIN3_EMAIL=exec.outreach@example.edu
ADMIN3_PASSWORD=change-me-strong

# Session lifetime for app cookies
SESSION_TTL_DAYS=7
